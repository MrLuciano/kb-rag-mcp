# ──────────────────────────────────────────────────────────────────────────────
# .env.gaming  —  Gaming Machine (Ryzen 7 8845HS, Windows + WSL2)
# ──────────────────────────────────────────────────────────────────────────────
# Embedding via LM Studio remoto na rede local
# EMBED_BACKEND recomendado: openai-compat (HTTP puro, funciona remoto sem SDK)
# Use lmstudio-sdk apenas se o WSL2 e o LM Studio estiverem na MESMA máquina
EMBED_BACKEND=openai-compat
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5-embedding

# URL base do LM Studio — apenas host:porta, SEM /v1 ou /api/v0
# O código adiciona o path correto automaticamente por backend
LMS_BASE_URL=http://192.168.1.177:1234

# Qdrant rodando no WSL2 via Docker
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=kb_docs

# Score mínimo de relevância (0.0 a 1.0)
SCORE_THRESHOLD=0.35

# Transporte MCP: stdio para Claude Code/OpenCode, sse para acesso via URL
MCP_TRANSPORT=stdio

# Logs
LOG_PATH=/tmp/kb-mcp.log

# Docs path (WSL2 vê o Windows em /mnt/c/, /mnt/d/, etc.)
# DOCS_PATH=/mnt/d/kb-docs
