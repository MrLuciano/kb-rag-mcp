# ──────────────────────────────────────────────────────────────────────────────
# .env.proxmox  —  Proxmox LXC (CPU only, Ollama)
# ──────────────────────────────────────────────────────────────────────────────
# Embedding via Ollama (local, CPU)
EMBED_BACKEND=ollama
EMBED_MODEL=nomic-embed-text
OLLAMA_HOST=http://localhost:11434

# Qdrant Docker no mesmo LXC
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=kb_docs

SCORE_THRESHOLD=0.35

# SSE para acesso via rede local (Claude Code usa SSH wrapper ou URL direta)
MCP_TRANSPORT=sse
SSE_HOST=0.0.0.0
SSE_PORT=8765

LOG_PATH=/var/log/kb-mcp.log
DEFAULT_TOP_K=5
