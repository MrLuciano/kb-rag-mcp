# kb-rag-mcp configuration template
# Copy this file to .env and fill in your values.
# DO NOT commit .env or config/.env.local to git.

# MCP Transport Configuration
MCP_TRANSPORT=sse
SSE_HOST=0.0.0.0
SSE_PORT=8765

# Qdrant Configuration
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=kb_documents

# Embedding Service Configuration
# Choose one backend: lmstudio-rest, openai-compat, ollama
EMBED_URL=http://localhost:1234
EMBED_BACKEND=lmstudio-rest
EMBED_MODEL=your-model-name-here

# Optional: Ollama embedding backend (local, no GPU needed)
# OLLAMA_HOST=http://localhost:11434
# EMBED_BACKEND=ollama
# EMBED_MODEL=nomic-embed-text:v1.5
# EMBED_DIM=768

# Document Processing Configuration
DOCS_PATH=/path/to/your/docs
WATCH_PATH=/path/to/your/docs

# Data and Logging Paths
DATA_DIR=./data
LOGS_DIR=./logs
QDRANT_DATA_PATH=./data/qdrant
KB_METADATA_DB=data/kb_metadata.db
