# ──────────────────────────────────────────────────────────────────────────────
# .env.local  —  Local Machine (Windows + WSL2 + LM Studio)
# ──────────────────────────────────────────────────────────────────────────────
# Embedding via LM Studio running on the local network
# EMBED_BACKEND recommended: openai-compat (pure HTTP, works remotely without SDK)
# Use lmstudio-sdk only if WSL2 and LM Studio are on the SAME machine
EMBED_BACKEND=openai-compat
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5-embedding
# Recommended embedding models (via LM Studio or Ollama):
#   - nomic-embed-text v1.5  — balanced, multilingual, MIT license (768-dim)
#   - mxbai-embed-large-v1   — fast on CPU, MTEB top-10 (1024-dim)
#   - bge-m3                 — best quality, dense+sparse unified (1024-dim)

# URL base do LM Studio — apenas host:porta, SEM /v1 ou /api/v0
# O código adiciona o path correto automaticamente por backend
LMS_BASE_URL=http://<LM_STUDIO_HOST>:1234

# Qdrant rodando no WSL2 via Docker
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=kb_docs

# Score mínimo de relevância (0.0 a 1.0)
SCORE_THRESHOLD=0.35

# Transporte MCP: stdio para Claude Code/OpenCode, sse para acesso via URL
MCP_TRANSPORT=stdio

# Logs
LOG_PATH=/tmp/kb-mcp.log

# Docs path (WSL2 vê o Windows em /mnt/c/, /mnt/d/, etc.)
# DOCS_PATH=/mnt/d/kb-docs
