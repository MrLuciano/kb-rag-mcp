          "datasource": { "type": "prometheus", "uid": "prometheus" },
          "expr": "kb_ingest_worker_pool_queue_size",
          "legendFormat": "queue size"
        }
      ]
    },
    {
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "fieldConfig": {
        "defaults": {
          "unit": "percentunit",
          "min": 0,
          "max": 1,
