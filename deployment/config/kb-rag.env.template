# ═══════════════════════════════════════════════════════════════
# KB-RAG Configuration Template
# ═══════════════════════════════════════════════════════════════
#
# Copy this file to /opt/kb-rag/config/kb-rag.env and customize
# for your environment.
#

# ── Embedding Service ────────────────────────────────────────────
# Backend: lmstudio | ollama | openai-compat
EMBED_BACKEND=openai-compat

# Model name (backend-specific)
EMBED_MODEL=text-embedding-nomic-embed-text-v1.5-embedding

# LM Studio base URL (for openai-compat backend)
LMS_BASE_URL=http://localhost:1234

# Ollama base URL (if using ollama backend)
# OLLAMA_BASE_URL=http://localhost:11434

# OpenAI API (if using openai backend)
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1

# ── Vector Store (Qdrant) ────────────────────────────────────────
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_COLLECTION=kb_docs

# Use gRPC for better performance (FASE 8)
QDRANT_PREFER_GRPC=false
QDRANT_GRPC_PORT=6334

# ── Cache Configuration ──────────────────────────────────────────
# Backend: lru | redis | disabled
CACHE_BACKEND=lru

# LRU cache settings (auto-tuned to 10% RAM if not set)
CACHE_MAX_SIZE_MB=512
CACHE_TTL=3600

# Redis cache settings (if using redis backend)
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
# REDIS_DB=0

# ── Batch Processing (FASE 8) ────────────────────────────────────
# Auto-tuned based on RAM/CPU if not set

# Embedding batch size (25-64 recommended)
EMBED_BATCH_SIZE=32

# File processing batch size (50-100 recommended)
FILE_BATCH_SIZE=50

# Qdrant upsert batch size (80-200 recommended)
QDRANT_BATCH_SIZE=100

# HTTP connection pool size (20-50 recommended)
HTTP_POOL_CONNECTIONS=20

# Parallel uploads to Qdrant (1-5 recommended)
MAX_CONCURRENT_UPLOADS=3

# ── Health Check Server ──────────────────────────────────────────
HEALTH_HOST=0.0.0.0
HEALTH_PORT=8000

# ── MCP Server ───────────────────────────────────────────────────
# Transport: stdio | sse
MCP_TRANSPORT=stdio

# SSE transport settings (if using sse)
SSE_HOST=0.0.0.0
SSE_PORT=8765

# Default search results
DEFAULT_TOP_K=5

# ── Logging ──────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_PATH=/opt/kb-rag/logs/kb-rag.log

# JSON logging for observability
LOG_FORMAT=json

# ── Job Management ───────────────────────────────────────────────
# Worker pool configuration
WORKER_POOL_SIZE=4
WORKER_RATE_LIMIT=10

# Job database path
JOB_DB_PATH=/opt/kb-rag/data/kb_metadata.db

# ── File Watcher (FASE 13) ───────────────────────────────────────
# Directory to monitor for changes
WATCH_PATH=/opt/kb-rag/docs

# Debounce window in seconds (batches changes within this window)
WATCH_DEBOUNCE_SECONDS=30

# Comma-separated patterns to ignore (temp files, etc.)
WATCH_IGNORE_PATTERNS=.tmp,.swp,.~,~$*

# Monitor subdirectories recursively
WATCH_RECURSIVE=true

# ── Document Processing ──────────────────────────────────────────
# Chunking strategy
CHUNK_SIZE=512
CHUNK_OVERLAP=50

# Document validation (enable for production)
SKIP_VALIDATION=false

# Max file size (MB)
MAX_FILE_SIZE_MB=100

# ── Observability ────────────────────────────────────────────────
# Prometheus metrics endpoint (via health server)
METRICS_ENABLED=true

# Metrics port (same as health server)
METRICS_PORT=8000

# ── Security ─────────────────────────────────────────────────────
# No authentication required (internal use)
# Add authentication in reverse proxy if needed
